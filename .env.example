APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=3000

# Keep dev state out of the checked-in legacy data snapshot.
APP_DATA_DIR=target/dev/data

# Preserve the default local manuscript workspace root.
APP_BOOKS_ROOT=books-data

FRONTEND_BASE_URL=http://127.0.0.1:5173
CADDY_SITE_ADDRESS=http://127.0.0.1:5173
PUBLIC_BACKEND_BASE_URL=http://127.0.0.1:3000

WEB_AUTH_USERNAME=book
WEB_AUTH_PASSWORD=123
JWT_SIGNING_SECRET=dev-jwt-signing-secret

# Local Codex execution defaults.
CODEX_CLI_PATH=codex
# Set the model we want the book-writing agent to use through Codex CLI args.
CODEX_CLI_ARGS="--model gpt-5.4"
AGENT_TIMEOUT_SECS=600
