APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=3000
APP_DATA_DIR=/var/lib/book-writer-chat/state
APP_BOOKS_ROOT=/var/lib/book-writer-chat/books-data
FRONTEND_DIST_DIR=/opt/book-writer-chat/frontend/build
FRONTEND_BASE_URL=https://books.example.com
WEB_AUTH_USERNAME=operator
WEB_AUTH_PASSWORD=replace-me
JWT_SIGNING_SECRET=replace-me-with-a-long-random-secret
CODEX_CLI_PATH=/opt/book-writer-chat/codex
# Set the model we want the book-writing agent to use through Codex CLI args.
CODEX_CLI_ARGS="--model gpt-5.4"
AGENT_TIMEOUT_SECS=60
# Must be the bare public hostname, not a URL and not :80.
# Correct: books.example.com
# Wrong: https://books.example.com, http://books.example.com, :80
CADDY_SITE_ADDRESS=books.example.com
XDG_DATA_HOME=/var/lib/book-writer-chat/caddy-data
XDG_CONFIG_HOME=/var/lib/book-writer-chat/caddy-config
